{
  "name": "envly",
  "private": true,
  "description": "Envly tool monorepo for managing secrets and env variables",
  "author": "Alberto Fabro",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/eiliv17/envly.git"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm -r do-postinstall",
    "dev": "pnpm -r do-dev",
    "build": "pnpm -r do-build",
    "lint": "pnpm -r do-lint",
    "typecheck": "pnpm -r do-typecheck",
    "dev:desktop": "pnpm --filter envly-desktop tauri dev",
    "dev:website": "pnpm --filter envly-website do-dev",
    "build:desktop": "pnpm --filter envly-desktop tauri build",
    "build:website": "pnpm --filter envly-website do-build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [ "@tailwindcss/oxide", "unrs-resolver" ]
  }
}